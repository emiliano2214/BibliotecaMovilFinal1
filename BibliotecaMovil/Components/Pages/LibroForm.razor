@page "/libro-form"
@page "/libro-form/{IdLibro:int}"
@using BibliotecaMovil.Shared.DTOs
@using BibliotecaMovil.Shared.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav
@inject ILibroService LibroService
@inject IAutorService AutorService
@inject IEditorialService EditorialService
@inject ICategoriaService CategoriaService
@inject BibliotecaMovil.Services.UsuarioSesionService Sesion
@attribute [Authorize(Roles = "Admin,Bibliotecario")]

<div style="background:#777FF5; min-height:100vh; display:flex; flex-direction:column;">
    <div style="padding:40px 20px 10px 20px; display:grid; grid-template-columns:auto 1fr auto; column-gap:10px; align-items:center;">
        <div style="width:80px; height:80px; background:white; display:flex; align-items:center; justify-content:center;">
            <div style="width:64px; height:64px; background:gray; border-radius:32px;"></div>
        </div>

        <div style="font-weight:bold; font-size:22px;">
            @(EsEdicion ? "Editar Libro" : "Nuevo Libro")
        </div>

        <div style="background:#0050FF; width:40px; height:40px; display:flex; align-items:center; justify-content:center;">
            <span style="font-size:22px;">📚</span>
        </div>
    </div>

    <div style="flex:1; background:white; padding:20px;">
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div style="background:#ffdddd; color:#900; padding:10px; margin-bottom:15px; border-radius:6px;">
                ⚠️ @error
            </div>
        }

        @if (cargando)
        {
            <div style="padding:10px;">Cargando...</div>
        }
        else
        {
            <div>Título</div>
            <InputText @bind-Value="dto.Titulo"
                       style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;" />

            <div>Resumen</div>
            <InputText @bind-Value="dto.Resumen"
                       style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;" />

            <div>Fecha de emisión</div>
            <InputDate @bind-Value="dto.FechaEmision"
                       style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;" />

            <div>Autor</div>
            <InputSelect @bind-Value="dto.AutorId"
                         style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;">
                <option value="0">-- Seleccione un autor --</option>
                @foreach (var a in autores)
                {
                    <option value="@a.IdAutor">@($"{a.Apellidos}, {a.Nombre}")</option>
                }
            </InputSelect>

            <div>Editorial</div>
            <InputSelect @bind-Value="dto.EditorialId"
                         style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;">
                <option value="0">-- Seleccione una editorial --</option>
                @foreach (var e in editoriales)
                {
                    <option value="@e.IdEditorial">@e.Nombre</option>
                }
            </InputSelect>

            <div>Categoría</div>
            <InputSelect @bind-Value="dto.CategoriaId"
                         style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:10px;">
                <option value="0">-- Seleccione una categoría --</option>
                @foreach (var c in categorias)
                {
                    <option value="@c.IdCategoria">@c.Nombre</option>
                }
            </InputSelect>

            <div>Cantidad de ejemplares</div>
            <InputNumber @bind-Value="dto.CantidadEjemplares"
                         style="width:100%; height:34px; background:#DDDDDD; border:none; margin-bottom:20px;" />

            <div style="display:grid; grid-template-columns:1fr 1fr; grid-column-gap:20px; margin-top:10px;">
                <button disabled="@guardando"
                        style="height:44px; background:#0050FF; border:none; color:black;"
                        @onclick="Guardar">
                    @(guardando ? "Guardando..." : "Aceptar")
                </button>

                <button disabled="@guardando"
                        style="height:44px; background:red; border:none; color:black;"
                        @onclick="Cancelar">
                    Cancelar
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int? IdLibro { get; set; }
    private bool EsEdicion => IdLibro.HasValue && IdLibro.Value > 0;

    private LibroCreateDto dto = new() { CantidadEjemplares = 1 };

    private List<AutorDto> autores = new();
    private List<EditorialDto> editoriales = new();
    private List<CategoriaDto> categorias = new();

    private string? error;
    private bool cargando;
    private bool guardando;

    protected override async Task OnInitializedAsync()
    {
        var user = await Sesion.ObtenerUsuarioAsync();
        if (user is null)
        {
            Nav.NavigateTo("/", true);
            return;
        }

        await CargarCombos();
    }

    private async Task CargarCombos()
    {
        try
        {
            cargando = true;
            error = null;

            autores = await AutorService.GetAutoresAsync() ?? new();
            editoriales = await EditorialService.GetEditorialesAsync() ?? new();
            categorias = await CategoriaService.GetCategoriasAsync() ?? new();
        }
        catch (Exception ex)
        {
            error = "Error cargando listas: " + ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task Guardar()
    {
        error = null;

        if (string.IsNullOrWhiteSpace(dto.Titulo))
        {
            error = "El título es obligatorio.";
            return;
        }

        if (dto.AutorId <= 0 || dto.EditorialId <= 0 || dto.CategoriaId <= 0)
        {
            error = "Debe seleccionar Autor, Editorial y Categoría.";
            return;
        }

        if (dto.CantidadEjemplares <= 0)
        {
            error = "La cantidad de ejemplares debe ser mayor a 0.";
            return;
        }

        try
        {
            guardando = true;

            bool ok;
            if (EsEdicion)
            {
                var upd = new LibroUpdateDto
                {
                    Titulo = dto.Titulo,
                    Resumen = dto.Resumen,
                    FechaEmision = dto.FechaEmision,
                    AutorId = dto.AutorId,
                    EditorialId = dto.EditorialId,
                    CategoriaId = dto.CategoriaId,
                    CantidadEjemplares = dto.CantidadEjemplares
                };

                ok = await LibroService.UpdateLibroAsync(IdLibro!.Value, upd);
            }
            else
            {
                ok = await LibroService.AddLibroAsync(dto);
            }

            if (!ok)
            {
                error = EsEdicion ? "No se pudo actualizar el libro." : "No se pudo guardar el libro.";
                return;
            }

            Nav.NavigateTo("/libros");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void Cancelar() => Nav.NavigateTo("/libros");
}