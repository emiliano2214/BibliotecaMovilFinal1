@page "/registro"
@using BibliotecaMovil.Shared.DTOs
@using BibliotecaMovil.Shared.Interfaces
@inject NavigationManager Navigation
@inject IUsuarioAuthService UsuarioAuthService
@inject IRolService RolService

<div style="background:#777FF5; min-height:100vh; padding:60px 20px 20px 20px;">
    <div style="font-size:32px; text-align:center; margin-bottom:30px;">Registro</div>

    <div style="background:white; padding:20px;">

        @if (!string.IsNullOrWhiteSpace(mensajeError))
        {
            <div style="background:#ffdddd; color:#900; padding:10px; margin-bottom:15px; border-radius:6px;">
                ⚠️ @mensajeError
            </div>
        }

        @if (cargandoRoles)
        {
            <div style="margin-bottom:10px;">Cargando roles...</div>
        }

        <div>Nombre</div>
        <input @bind="registerRequestDto.Nombre"
               style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:10px;" />

        <div>Apellido</div>
        <input @bind="registerRequestDto.Apellido"
               style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:10px;" />

        <div>Email</div>
        <input @bind="registerRequestDto.Email"
               style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:10px;" />

        <div>Rol</div>
        <select @bind="registerRequestDto.RolId"
                style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:10px;">
            <option value="0">-- Seleccione un rol --</option>

            @foreach (var rol in roles)
            {
                <option value="@rol.IdRol">@rol.NombreRol</option>
            }
        </select>

        <div>Contraseña</div>
        <input type="password"
               @bind="registerRequestDto.Password"
               style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:10px;" />

        <div>Repetir Contraseña</div>
        <input type="password"
               @bind="repetirPassword"
               style="width:100%; height:36px; background:#DDDDDD; border:none; margin-bottom:20px;" />

        <div style="display:grid; grid-template-columns:1fr 1fr; grid-column-gap:20px; margin-top:10px;">
            <button disabled="@cargando"
                    style="height:44px; background:#0050FF; border:none; color:black;"
                    @onclick="Registrar">
                @(cargando ? "Registrando..." : "Aceptar")
            </button>

            <button disabled="@cargando"
                    style="height:44px; background:red; border:none; color:black;"
                    @onclick="Cancelar">
                Cancelar
            </button>
        </div>
    </div>
</div>

@code {
    public RegisterRequestDto registerRequestDto = new();
    private string repetirPassword = "";
    private string? mensajeError;
    private bool cargando = false;

    // roles
    private List<RolDto> roles = new();
    private bool cargandoRoles = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargandoRoles = true;

            var lista = await RolService.GetRolesAsync();

            // Excluir Admin (por NombreRol)
            roles = lista
                .Where(r => !string.Equals(r.NombreRol, "Admin", StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch (Exception ex)
        {
            mensajeError = "No se pudieron cargar los roles: " + ex.Message;
        }
        finally
        {
            cargandoRoles = false;
        }
    }

    private async Task Registrar()
    {
        mensajeError = null;

        // Validaciones básicas
        if (string.IsNullOrWhiteSpace(registerRequestDto.Nombre) ||
            string.IsNullOrWhiteSpace(registerRequestDto.Email) ||
            string.IsNullOrWhiteSpace(registerRequestDto.Password))
        {
            mensajeError = "Completá Nombre, Email y Contraseña.";
            return;
        }

        if (registerRequestDto.RolId <= 0)
        {
            mensajeError = "Seleccione un rol.";
            return;
        }

        if (registerRequestDto.Password != repetirPassword)
        {
            mensajeError = "Las contraseñas no coinciden.";
            return;
        }

        try
        {
            cargando = true;

            // completar campos internos (si tu API los espera / DB los necesita)
            registerRequestDto.Activo = true;
            registerRequestDto.FechaAlta = DateTime.Now;

            var result = await UsuarioAuthService.RegisterDebugAsync(registerRequestDto);

            if (!result.Ok)
            {
                mensajeError = $"No se pudo registrar. ({result.StatusCode}) {result.Body}";
                return;
            }

            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            mensajeError = $"Error en el registro: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/");
    }
}